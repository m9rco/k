# ---- Common fallback (shared by every model backend) ----
# Semantically-neutral shared credential + base URL. Any backend that lacks its
# own dedicated *_PROVIDER / *_BASE_URL / *_API_KEY inherits these. To move one
# model to a different provider later, set only that model's dedicated vars.
COMMON_API_KEY=sk-your-key-here
COMMON_BASE_URL=https://yunwu.ai/v1
# COMMON_PROVIDER=openai
#
# Legacy aliases (still honored, below COMMON_*): YUNWU_API_KEY, YUNWU_BASE_URL.

# Per-model overrides resolve independently, per field:
#   <PREFIX>_PROVIDER / <PREFIX>_BASE_URL / <PREFIX>_API_KEY → COMMON_* → built-in
#   <PREFIX>_MODEL has no common tier (each backend has its own default).

# ---- Chat models (逻辑推理 / 主 agent) ----
# Primary conversation model. Provider selects the protocol branch:
#   openai  -> chat/completions (gpt-5.4, doubao-seed-2-0-mini-260428, deepseek)
#   anthropic -> Messages API   (claude-sonnet-4-6, claude-haiku-4-5-20251001)
CHAT_PRIMARY_PROVIDER=openai
CHAT_PRIMARY_MODEL=deepseek-v4-flash
# Examples (set provider + model together):
#   CHAT_PRIMARY_PROVIDER=openai     CHAT_PRIMARY_MODEL=gpt-5.4
#   CHAT_PRIMARY_PROVIDER=openai     CHAT_PRIMARY_MODEL=doubao-seed-2-0-mini-260428
#   CHAT_PRIMARY_PROVIDER=anthropic  CHAT_PRIMARY_MODEL=claude-sonnet-4-6
#   CHAT_PRIMARY_PROVIDER=anthropic  CHAT_PRIMARY_MODEL=claude-haiku-4-5-20251001
# CHAT_PRIMARY_BASE_URL=
# CHAT_PRIMARY_API_KEY=
# Test model, switched in when USE_TEST_MODEL=true (default: claude-sonnet-4-5).
CHAT_TEST_PROVIDER=openai
CHAT_TEST_MODEL=claude-sonnet-4-5-20250929
# CHAT_TEST_API_KEY=   # alias: DEEPSEEK_API_KEY
# USE_TEST_MODEL=false

# ---- Image generation (图生图: 主 + 备 failover) ----
# Provider selects the adapter:
#   openai (default) -> /v1/images/{generations,edits}, b64_json (gpt-image-2)
#   gemini           -> :generateContent + inline_data (Gemini image models)
IMAGE_PRIMARY_PROVIDER=openai
IMAGE_PRIMARY_MODEL=gpt-image-2
IMAGE_BACKUP_PROVIDER=openai
IMAGE_BACKUP_MODEL=gpt-image-2
# Gemini examples (set provider=gemini + a model + its base_url/api_key):
#   IMAGE_PRIMARY_PROVIDER=gemini  IMAGE_PRIMARY_MODEL=gemini-3-pro-image
#   IMAGE_PRIMARY_MODEL=gemini-2.5-flash-image | gemini-3.1-flash-image | gemini-3.1-flash-image-preview
# IMAGE_PRIMARY_BASE_URL=   # falls back to COMMON_BASE_URL
# IMAGE_PRIMARY_API_KEY=    # falls back to COMMON_API_KEY

# ---- Text-to-image (文生图: wan/qwen, async task) ----
# Disabled until TEXT_TO_IMAGE_API_KEY (or COMMON_API_KEY) + a model are set.
# Provider defaults to "dashscope" (Alibaba image-synthesis async flow).
# TEXT_TO_IMAGE_PROVIDER=dashscope
# TEXT_TO_IMAGE_MODEL=wan2.7-image-pro       # or qwen-image-2.0-2026-03-03
# TEXT_TO_IMAGE_BASE_URL=                     # falls back to COMMON_BASE_URL
# TEXT_TO_IMAGE_API_KEY=                      # falls back to COMMON_API_KEY

# ---- Server / storage (optional, shown with defaults) ----
# ADDR=:8080
# DB_PATH=data/asset-studio.db
# ASSET_DIR=data/assets
# CONTEXT_TOKEN_BUDGET=8000

# ---- Diagnostic logging (trace 链路日志, optional) ----
# Structured JSON logs, one record per line, tagged with trace_id (one per turn)
# and session_id. Pull a single turn's full chain with:
#   jq 'select(.trace_id=="trace_...")' data/logs/app.log
# LOG_FILE empty => stderr only (historical behaviour).
# LOG_FILE=data/logs/app.log
# LOG_LEVEL=info            # debug | info | warn | error
# LOG_MIRROR_STDERR=false   # also echo a human-readable view to stderr (dev)

# ---- Video generation (图生视频) ----
# Provider selects the adapter:
#   happyhorse (default) -> DashScope video-synthesis async task
#   veo                  -> Google Veo image-to-video async task
# Canonical names are VIDEO_*; HAPPYHORSE_* remain as aliases.
# VIDEO_PROVIDER=happyhorse
# VIDEO_MODEL=happyhorse-1.0-r2v        # alias: HAPPYHORSE_MODEL
# VIDEO_BASE_URL=https://yunwu.ai/alibailian   # alias: HAPPYHORSE_BASE_URL
# VIDEO_API_KEY=                        # alias: HAPPYHORSE_API_KEY; else COMMON_API_KEY
# Veo example:
#   VIDEO_PROVIDER=veo  VIDEO_MODEL=veo_3_1_fast_components_vip   (or veo_3_1_components_vip)

# ---- Game-asset crawling — endpoint has NO common fallback ----
# Unset endpoint => crawl capability stays "not configured".
# CRAWL_BASE_URL=                       # alias: CRAWL_ENDPOINT
# CRAWL_API_KEY=                        # else falls back to COMMON_API_KEY
