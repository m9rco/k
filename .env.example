# ---- Common fallback (shared by every model backend) ----
# Semantically-neutral shared credential + base URL. Any backend that lacks its
# own dedicated *_PROVIDER / *_BASE_URL / *_API_KEY inherits these. To move one
# model to a different provider later, set only that model's dedicated vars.
COMMON_API_KEY=sk-your-key-here
COMMON_BASE_URL=https://yunwu.ai/v1
# COMMON_PROVIDER=openai
#
# Legacy aliases (still honored, below COMMON_*): YUNWU_API_KEY, YUNWU_BASE_URL.

# Per-model overrides resolve independently, per field:
#   <PREFIX>_PROVIDER / <PREFIX>_BASE_URL / <PREFIX>_API_KEY → COMMON_* → built-in
#   <PREFIX>_MODEL has no common tier (each backend has its own default).

# ---- Chat models ----
# Primary conversation model (default: deepseek-v4-flash, OpenAI-compatible).
CHAT_PRIMARY_PROVIDER=openai
CHAT_PRIMARY_MODEL=deepseek-v4-flash
# CHAT_PRIMARY_BASE_URL=
# CHAT_PRIMARY_API_KEY=
# Test model, switched in when USE_TEST_MODEL=true (default: claude-sonnet-4-5).
CHAT_TEST_PROVIDER=openai
CHAT_TEST_MODEL=claude-sonnet-4-5-20250929
# CHAT_TEST_API_KEY=   # alias: DEEPSEEK_API_KEY
# USE_TEST_MODEL=false

# ---- Image generation (gpt-image-2 over /v1/images/{generations,edits}) ----
IMAGE_PRIMARY_MODEL=gpt-image-2
IMAGE_BACKUP_MODEL=gpt-image-2
# IMAGE_PRIMARY_BASE_URL=   # falls back to COMMON_BASE_URL
# IMAGE_PRIMARY_API_KEY=    # falls back to COMMON_API_KEY

# ---- Server / storage (optional, shown with defaults) ----
# ADDR=:8080
# DB_PATH=data/asset-studio.db
# ASSET_DIR=data/assets
# CONTEXT_TOKEN_BUDGET=8000

# ---- Video generation (happyhorse R2V) — not yet wired, reserved ----
# Canonical names are VIDEO_*; HAPPYHORSE_* remain as aliases.
# VIDEO_MODEL=happyhorse-1.0-r2v        # alias: HAPPYHORSE_MODEL
# VIDEO_BASE_URL=https://yunwu.ai/alibailian   # alias: HAPPYHORSE_BASE_URL
# VIDEO_API_KEY=                        # alias: HAPPYHORSE_API_KEY; else COMMON_API_KEY

# ---- Game-asset crawling — endpoint has NO common fallback ----
# Unset endpoint => crawl capability stays "not configured".
# CRAWL_BASE_URL=                       # alias: CRAWL_ENDPOINT
# CRAWL_API_KEY=                        # else falls back to COMMON_API_KEY
